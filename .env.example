# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.
#
# These are the only values that cannot go in config.local.yaml:
#   - ENTRA_ID_CLIENT_SECRET  can technically go in the yaml, but keeping
#                             secrets out of files is cleaner
#   - UNION_CLIENT_SECRET     must be an env var — the uctl binary resolves
#                             it by name at runtime
#   - SESSION_SECRET          generate with: openssl rand -base64 32

ENTRA_ID_CLIENT_SECRET=
UNION_CLIENT_SECRET=
SESSION_SECRET=
